<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="API Test Suite" thread-count="5" parallel="methods">

    <listeners>
        <listener
                class-name="com.api.listeners.TestListener"/>
    </listeners>

    <test  name="API Tests">

        <classes>
            <class name="com.api.tests.LoginAPITest"/>
            <class name="com.api.tests.CreateAccountsAPITest"/>
            <class name="com.api.tests.FetchAccountDetailsAPITest"/>
            <class name="com.api.tests.FetchAllAccountDetailsAPITest"/>
            <class name="com.api.tests.FetchUserDetailsAPITest"/>
            <class name="com.api.tests.UpdateUserDetailsAPITest"/>
            <class name="com.api.tests.TransferFundAPITest"/>
        </classes>
    </test>
</suite>
